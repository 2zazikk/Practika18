<Window x:Class="EventOrganizerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Организатор мероприятий"
        Height="550"
        Width="900">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая часть -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="Мероприятия"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 15"/>

            <ListBox ItemsSource="{Binding Events}"
                     SelectedItem="{Binding SelectedEvent}"
                     Height="300">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                Margin="5"
                                Padding="10">

                            <StackPanel>

                                <TextBlock Text="{Binding Title}"
                                           FontWeight="Bold"
                                           FontSize="18"/>

                                <TextBlock Text="{Binding Date}"
                                           Margin="0 5 0 0"/>

                                <TextBlock Text="{Binding Description}"
                                           Margin="0 5 0 0"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <!-- Поля ввода -->
            <TextBlock Text="Имя"
                       Margin="0 15 0 5"
                       FontWeight="Bold"/>

            <TextBox Text="{Binding ParticipantName}"
                     Height="30"/>

            <TextBlock Text="Почта"
                       Margin="0 10 0 5"
                       FontWeight="Bold"/>

            <TextBox Text="{Binding ParticipantEmail}"
                     Height="30"/>

            <Button Content="Зарегистрироваться"
                    Width="200"
                    Height="40"
                    Margin="0 20 0 0"
                    Command="{Binding RegisterCommand}"/>

        </StackPanel>

        <!-- Правая часть -->
        <StackPanel Grid.Column="1"
                    Margin="20 0 0 0">

            <TextBlock Text="Календарь"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0 0 0 10"/>

            <Calendar Height="250"/>

            <TextBlock Text="Участники"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0 20 0 10"/>

            <ListBox ItemsSource="{Binding Participants}">

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Border BorderBrush="LightGray"
                                BorderThickness="1"
                                Margin="5"
                                Padding="5">

                            <StackPanel>

                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Email}"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

        </StackPanel>

    </Grid>
</Window>